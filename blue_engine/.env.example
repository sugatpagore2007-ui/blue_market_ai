# Blue Forex Market AI - environment example
# Keep real trading disabled until you have tested everything on demo.

BROKER_PROFILE=auto
BROKER_PLATFORM=mt5

# MT5 credentials are optional if you login manually in the MT5 terminal first.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Safety
AUTO_TRADE_DEMO_ONLY=True
AUTO_TRADE_ALLOW_REAL_ACCOUNT=False
AUTO_TRADE_RISK_PERCENT=1.0
MAX_AUTO_TRADES_PER_DAY=4
MAX_DAILY_LOSS_PERCENT=2.0

# cTrader scaffold credentials. Execution is blocked until adapter is implemented.
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_ACCOUNT_ID=
